<div class="main-sidebar sidebar-style-2">
    <aside id="sidebar-wrapper">
        <div class="sidebar-brand">
            <a href=""> <img alt="image" src="{{self.asset_path("assets/img/logo.png")}}" class="header-logo" /> <span
                    class="logo-name"></span>
            </a>
        </div>
        <ul class="sidebar-menu">
            <li class="menu-header">Main</li>

            {{#each self.sidebar.items}}
                <li class="dropdown {{this.active(&self.sidebar.current_page)}}">

                    {{#if !this.children.is_empty() }}
                        <a href="{{this.page.get_route()}}" class="menu-toggle nav-link has-dropdown">
                            <i data-feather="{{this.icon}}"></i><span>{{this.title}}</span></a>
                    {{else}}
                        <a href="{{this.page.get_route()}}" class="nav-link"><i data-feather="{{this.icon}}"></i><span>{{this.title}}</span></a>

                    {{/if}}
                {{#if !this.children.is_empty() }}
                <ul class="dropdown-menu">

                    {{#each this.children}}
                     <li><a class="nav-link" href="{{this.page.get_route()}}">{{this.title}} </a></li>

                        {{/each}}

                </ul>

                {{/if}}

                </li>
                {{/each}}

        </ul>
    </aside>
</div>
